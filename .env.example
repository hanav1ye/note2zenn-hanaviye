# 必須: Zenn リポジトリのローカルパス（空だと起動時にエラー）
ZENN_REPO_PATH=

# LLM: ollama（既定）または openai
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:E2B

# LLM_PROVIDER=openai のとき必須
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini

# HTTPS の origin へ push するとき（任意・PAT）
#GITHUB_TOKEN=

# git commit の作者（任意・未設定時は bot 名義）
#GIT_AUTHOR_NAME=
#GIT_AUTHOR_EMAIL=
